# ===============================
# LeadStriker - Environment Variables
# ===============================

PORT=5000
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/leadstriker
SERPAPI_KEY=your_serpapi_key
FRONTEND_URL=https://leadstriker.pages.dev

# Facebook & Instagram (Graph API)
FACEBOOK_ACCESS_TOKEN=your_facebook_page_access_token
INSTAGRAM_BUSINESS_ID=your_instagram_business_id
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token

# LinkedIn (Proxycurl)
LINKEDIN_API_KEY=your_proxycurl_api_key
